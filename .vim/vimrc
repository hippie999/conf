function! KlipperCopy()
  let l:content = @"
  call system('qdbus org.kde.klipper /klipper setClipboardContents ' . shellescape(l:content))
endfunction

function! KlipperPaste()
  let @" = system('qdbus org.kde.klipper /klipper getClipboardContents')
  let @" = substitute(@", '\n\+$', '', '')
  normal! p
endfunction

nnoremap <leader>y y:call KlipperCopy()<CR>
vnoremap <leader>y y:call KlipperCopy()<CR>
nnoremap <leader>p :call KlipperPaste()<CR>

augroup VimConfig
    autocmd!

    autocmd TerminalOpen * 
        \ setlocal nonumber norelativenumber |
        \ tnoremap <buffer> <silent> <Esc> <C-\><C-n>

    autocmd FileType c,html,markdown,tex,json,jsonc,kdl,css,lua,sql 
        \ setlocal shiftwidth=2 tabstop=2

    autocmd FileType text,markdown,tex
        \ setlocal spell spelllang=ru,en |
        \ let &l:spellfile = expand('$HOME/.vim/spell/ru-en.utf-8.add')

    autocmd FileType markdown
        \ let b:filename = expand('%') |
        \ let b:output = expand('%:r') . '.pdf' |
        \ let &l:makeprg = 'pandoc --read=markdown+tex_math_dollars+tex_math_single_backslash ' . 
        \ b:filename . ' -o ' . b:output . 
        \ ' --pdf-engine=tectonic -V mainfont="Libertinus Serif"'

    autocmd FileType c setlocal makeprg=gcc\ -Wall\ -Wextra\ -Wconversion\ -Wshadow\ %

    autocmd FileType cpp setlocal makeprg=g++\ -g\ \$CXXFLAG\ %

    autocmd FileType python setlocal makeprg=python\ %

    autocmd FileType tex setlocal makeprg=tectonic\ %
augroup END


if exists('g:loaded_nohlsearch')
    finish
endif
let g:loaded_nohlsearch = 1

func! s:Nohlsearch()
    if v:hlsearch
        call feedkeys("\<cmd>nohlsearch\<cr>", 'm')
    endif
endfunc

augroup nohlsearch
    au!
    au CursorHold * call s:Nohlsearch()
    au InsertEnter * call s:Nohlsearch()
augroup END
